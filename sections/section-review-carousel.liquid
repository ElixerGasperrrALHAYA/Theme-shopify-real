<div class="review-carousel-section" style="--bg-color: {{ section.settings.bg_color }};">
  <div class="carousel-header-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="carousel-main-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    
    <div class="carousel-nav-buttons">
      <button class="carousel-btn prev-btn" aria-label="Previous">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="carousel-btn next-btn" aria-label="Next">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  </div>

  <div class="carousel-viewport">
    <div class="carousel-track" id="ReviewCarouselTrack-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="carousel-slide" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'slide-bg-img' }}
          {%- else -%}
            <div class="slide-bg-placeholder"></div>
          {%- endif -%}
          
          <div class="slide-content-overlay">
            <div class="slide-top-row">
              {%- if block.settings.top_tag != blank -%}
                <div class="glass-tag">{{ block.settings.top_tag }}</div>
              {%- else -%}
                <div></div> <!-- spacer -->
              {%- endif -%}
              
              <div class="glass-circle-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
              </div>
            </div>

            <div class="slide-bottom-content">
              {%- if block.settings.category_tag != blank -%}
                <div class="glass-tag category-tag">{{ block.settings.category_tag }}</div>
              {%- endif -%}
              
              {%- if block.settings.title != blank -%}
                <h3 class="slide-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              
              {%- if block.settings.description != blank -%}
                <p class="slide-desc">{{ block.settings.description }}</p>
              {%- endif -%}
              
              <div class="slide-footer-row">
                {%- if block.settings.rating != blank -%}
                  <span class="rating-text">{{ block.settings.rating }}</span>
                {%- endif -%}
                
                {%- if block.settings.duration != blank -%}
                  <span>{{ block.settings.duration }}</span>
                {%- endif -%}
                
                {%- if block.settings.year != blank -%}
                  <span>{{ block.settings.year }}</span>
                {%- endif -%}
              </div>
              
              <button class="play-action-btn" aria-label="Play">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
              </button>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .review-carousel-section {
    background-color: var(--bg-color);
    padding: 60px 20px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: #FFFFFF;
    overflow: hidden;
  }
  .carousel-header-container {
    max-width: 1200px;
    margin: 0 auto 30px auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 10px;
  }
  .carousel-main-heading {
    font-size: 2rem;
    font-weight: 800;
    margin: 0;
    color: inherit;
  }
  .carousel-nav-buttons {
    display: flex;
    gap: 12px;
  }
  .carousel-btn {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FFF;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    backdrop-filter: blur(10px);
  }
  .carousel-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: scale(1.05);
  }
  
  .carousel-viewport {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    /* Allows items to break out on the right if needed, but hides overflow on the container */
  }
  .carousel-track {
    display: flex;
    gap: 20px;
    will-change: transform;
    /* padding left for alignment */
    padding: 0 10px;
  }
  
  .carousel-slide {
    flex: 0 0 calc(85vw - 20px);
    max-width: 320px;
    aspect-ratio: 3 / 4;
    position: relative;
    border-radius: 28px;
    overflow: hidden;
    background-color: #1a1a1a;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    user-select: none;
  }
  
  @media (min-width: 768px) {
    .carousel-slide {
      flex: 0 0 320px;
    }
  }

  .slide-bg-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .slide-bg-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(45deg, #2a2a2a, #4a4a4a);
  }

  .slide-content-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.6) 40%, rgba(0,0,0,0.1) 100%);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 24px;
    pointer-events: none; /* Let clicks pass to background if needed */
  }

  .slide-top-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  
  .glass-tag {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #FFF;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .glass-circle-btn {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FFF;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .slide-bottom-content {
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
    padding-right: 50px; /* Space for play button */
  }

  .category-tag {
    width: fit-content;
    margin-bottom: 4px;
  }

  .slide-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
    color: #FFF;
  }

  .slide-desc {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
  }

  .slide-footer-row {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 4px;
    font-weight: 500;
  }

  .rating-text {
    color: #F5C518; /* Yellow star rating color */
    font-weight: 700;
  }

  .play-action-btn {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 44px;
    height: 44px;
    background: #FFF;
    color: #000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    transition: transform 0.2s;
    pointer-events: auto;
  }
  .play-action-btn:hover {
    transform: scale(1.1);
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', function() {
    const sections = document.querySelectorAll('.review-carousel-section');
    
    sections.forEach(section => {
      const track = section.querySelector('.carousel-track');
      const prevBtn = section.querySelector('.prev-btn');
      const nextBtn = section.querySelector('.next-btn');
      
      if (!track || !prevBtn || !nextBtn) return;
      
      let isAnimating = false;
      const gap = 20; // Matches CSS gap
      
      // We implement "infinite" by physically moving the DOM elements 
      // from the end to the start or vice versa, wrapping it with CSS transitions.
      
      nextBtn.addEventListener('click', () => {
        if (isAnimating) return;
        
        const slides = track.querySelectorAll('.carousel-slide');
        if (slides.length <= 1) return;
        
        isAnimating = true;
        const firstSlide = slides[0];
        const shiftAmount = firstSlide.offsetWidth + gap;
        
        // Animate the whole track to the left
        track.style.transition = 'transform 0.4s cubic-bezier(0.25, 1, 0.5, 1)';
        track.style.transform = `translateX(-${shiftAmount}px)`;
        
        // After transition, move the first element to the end and instantly reset transform
        setTimeout(() => {
          track.style.transition = 'none';
          track.style.transform = 'translateX(0)';
          track.appendChild(firstSlide);
          isAnimating = false;
        }, 400);
      });
      
      prevBtn.addEventListener('click', () => {
        if (isAnimating) return;
        
        const slides = track.querySelectorAll('.carousel-slide');
        if (slides.length <= 1) return;
        
        isAnimating = true;
        const lastSlide = slides[slides.length - 1];
        const shiftAmount = lastSlide.offsetWidth + gap;
        
        // Move the last element to the start instantly, and shift the track to the left
        // so it looks like it hasn't moved yet.
        track.style.transition = 'none';
        track.insertBefore(lastSlide, slides[0]);
        track.style.transform = `translateX(-${shiftAmount}px)`;
        
        // Force browser layout reflow
        void track.offsetWidth;
        
        // Animate back to 0
        track.style.transition = 'transform 0.4s cubic-bezier(0.25, 1, 0.5, 1)';
        track.style.transform = 'translateX(0)';
        
        setTimeout(() => {
          isAnimating = false;
        }, 400);
      });
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "Infinite Review Carousel",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Customer Experiences"
    }
  ],
  "blocks": [
    {
      "type": "review_card",
      "name": "Review Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "top_tag",
          "label": "Top Left Tag",
          "default": "U/A 16+"
        },
        {
          "type": "text",
          "id": "category_tag",
          "label": "Category Tag",
          "default": "Fantasy"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Harry Potter (2011)"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Harry Potter and the Deathly Hallows Part 2..."
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Rating (Yellow Text)",
          "default": "IMDb 8.3"
        },
        {
          "type": "text",
          "id": "duration",
          "label": "Detail 1 (e.g. Duration)",
          "default": "2h 10min"
        },
        {
          "type": "text",
          "id": "year",
          "label": "Detail 2 (e.g. Year)",
          "default": "2011"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Infinite Review Carousel",
      "category": "High Conversion",
      "blocks": [
        { "type": "review_card" },
        { "type": "review_card", "settings": { "top_tag": "U/A 13+", "category_tag": "Sci-Fi", "title": "Interstellar" } },
        { "type": "review_card", "settings": { "category_tag": "Sci-Fi", "title": "Inception" } },
        { "type": "review_card", "settings": { "title": "Tenet" } }
      ]
    }
  ]
}
{% endschema %}
