<div class="offer-urgency-wrapper" style="--bg-color: {{ section.settings.bg_color }}; --text-color: {{ section.settings.text_color }};">
  <div class="offer-urgency-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="offer-heading">{{ section.settings.heading }} {{ section.settings.heading_emoji }}</h2>
    {%- endif -%}

    {%- if section.settings.enable_timer -%}
      <div class="offer-timer" data-minutes="{{ section.settings.timer_minutes }}">
        <div class="timer-box"><span class="t-hours">00</span><small>Hours</small></div>
        <div class="timer-sep">:</div>
        <div class="timer-box"><span class="t-minutes">00</span><small>Minutes</small></div>
        <div class="timer-sep">:</div>
        <div class="timer-box"><span class="t-seconds">00</span><small>Seconds</small></div>
      </div>
    {%- endif -%}

    <div class="offer-context">
      {{ section.settings.context_text }}
    </div>

    <div class="offer-pricing-box">
      <h3 class="offer-pricing-title">Get instant access</h3>
      <div class="offer-price-row">
        {%- if section.settings.compare_price != blank -%}
          <span class="price-compare">{{ section.settings.compare_price }}</span>
        {%- endif -%}
        <span class="price-actual">{{ section.settings.actual_price }}</span>
      </div>
      
      {%- if section.settings.offer_details != blank -%}
        <div class="offer-details">
          {{ section.settings.offer_details }}
        </div>
      {%- endif -%}

      <a href="{{ section.settings.checkout_link | default: '/checkout' }}" 
         class="offer-checkout-btn"
         style="--btn-bg: {{ section.settings.btn_color }}; --btn-text: {{ section.settings.btn_text_color }};">
         {{ section.settings.btn_label }}
      </a>
      
      {%- if section.settings.microcopy != blank -%}
        <div class="offer-microcopy">
          {{ section.settings.microcopy }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .offer-urgency-wrapper {
    background-color: var(--bg-color);
    color: var(--text-color);
    padding: 80px 20px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    text-align: center;
  }
  .offer-urgency-container {
    max-width: 600px;
    margin: 0 auto;
  }
  .offer-heading {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 30px;
    letter-spacing: -0.02em;
  }
  .offer-timer {
    display: inline-flex;
    align-items: flex-start;
    justify-content: center;
    gap: 8px;
    margin-bottom: 40px;
  }
  .timer-box {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .timer-box span {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .timer-box small {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.6;
    margin-top: 4px;
  }
  .timer-sep {
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1;
    color: inherit;
    position: relative;
    top: -2px;
  }
  .offer-context {
    font-size: 1.1rem;
    line-height: 1.5;
    margin-bottom: 40px;
    opacity: 0.85;
  }
  .offer-pricing-box {
    background: #FFFFFF;
    color: #111111;
    border-radius: 16px;
    padding: 40px 30px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.08);
  }
  .offer-pricing-title {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 16px;
  }
  .offer-price-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }
  .price-compare {
    font-size: 1.25rem;
    text-decoration: line-through;
    color: #999;
    font-weight: 600;
  }
  .price-actual {
    font-size: 2.5rem;
    font-weight: 800;
    color: #111;
  }
  .offer-details {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 30px;
    text-align: center;
  }
  .offer-details p {
    margin: 4px 0;
  }
  .offer-checkout-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--btn-bg);
    color: var(--btn-text);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.25rem;
    padding: 16px 24px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(0,0,0,0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
  }
  .offer-checkout-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
  }
  .offer-microcopy {
    font-size: 0.85rem;
    margin-top: 20px;
    font-style: italic;
    opacity: 0.7;
  }
  
  @media (min-width: 768px) {
    .offer-heading { font-size: 3rem; }
    .timer-box span { font-size: 3.5rem; }
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', function() {
    const timers = document.querySelectorAll('.offer-timer');
    timers.forEach(timer => {
      const minutesData = parseInt(timer.getAttribute('data-minutes'), 10) || 15;
      
      const storageKey = 'offer_timer_end_' + window.location.pathname;
      let endTime = localStorage.getItem(storageKey);
      
      if (!endTime) {
        endTime = new Date().getTime() + minutesData * 60000;
        localStorage.setItem(storageKey, endTime);
      } else {
        endTime = parseInt(endTime, 10);
      }
      
      const updateTimer = () => {
        const now = new Date().getTime();
        const distance = endTime - now;
        
        if (distance < 0) {
          // Reset or keep at 0 depending on strategy. Here we keep at 00:00:00
          timer.querySelector('.t-hours').innerText = "00";
          timer.querySelector('.t-minutes').innerText = "00";
          timer.querySelector('.t-seconds').innerText = "00";
          return;
        }
        
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);
        
        timer.querySelector('.t-hours').innerText = hours.toString().padStart(2, '0');
        timer.querySelector('.t-minutes').innerText = minutes.toString().padStart(2, '0');
        timer.querySelector('.t-seconds').innerText = seconds.toString().padStart(2, '0');
      };
      
      updateTimer();
      setInterval(updateTimer, 1000);
    });
  });
{% endjavascript %}

