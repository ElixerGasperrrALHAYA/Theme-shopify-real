{{ 'twr-styles.css' | asset_url | stylesheet_tag }}

<div class="twr-wrapper">
  <section class="twr-agitation">
    <div class="twr-agitation-inner">
      <div class="twr-section-label">{{ section.settings.section_label }}</div>
      <h2>{{ section.settings.headline }}</h2>
      
      {% if section.settings.intro_paragraphs != blank %}
        <div class="twr-agitation-intro">
          {{ section.settings.intro_paragraphs }}
        </div>
      {% endif %}

      <ul class="twr-pain-list">
        {% for block in section.blocks %}
          <li><span class="twr-check">→</span> {{ block.settings.pain_point }}</li>
        {% endfor %}
      </ul>

      {% if section.settings.outro_paragraph != blank %}
        <div class="twr-agitation-outro">
          {{ section.settings.outro_paragraph }}
        </div>
      {% endif %}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "TWR Agitation",
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Section Label",
      "default": "Sound familiar?"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "You're Not Weak. Your Body Is Fighting You at the Wrong Times."
    },
    {
      "type": "richtext",
      "id": "intro_paragraphs",
      "label": "Intro Paragraphs",
      "default": "<p>You've been eating better. You've been trying. And then <strong>3pm hits</strong> — and something in you just breaks. The crackers. The chocolate. The \"just a little\" that turns into a lot.</p><p>It's not a character flaw. It's biology. After 35, your hormones shift in ways that make certain moments of the day <strong>almost impossible to navigate without a strategy</strong>. And nobody ever gave you that strategy.</p>"
    },
    {
      "type": "richtext",
      "id": "outro_paragraph",
      "label": "Outro Paragraph",
      "default": "<p>Here's the truth: <strong>Cravings aren't random.</strong> They follow a pattern. And once you know the three moments they strike — and what to do in each one — everything changes.</p>"
    }
  ],
  "blocks": [
    {
      "type": "pain_point",
      "name": "Pain Point",
      "settings": [
        {
          "type": "text",
          "id": "pain_point",
          "label": "Text",
          "default": "You start the day strong… and fall apart by afternoon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TWR Agitation",
      "blocks": [
        { "type": "pain_point", "settings": { "pain_point": "You start the day strong… and fall apart by afternoon" } },
        { "type": "pain_point", "settings": { "pain_point": "You're not even hungry — but something is pulling you toward the pantry" } },
        { "type": "pain_point", "settings": { "pain_point": "You've tried cutting carbs, counting calories, even the expensive supplements — but the cravings always come back" } },
        { "type": "pain_point", "settings": { "pain_point": "At night, when everyone's asleep, you eat things you promised yourself you wouldn't" } },
        { "type": "pain_point", "settings": { "pain_point": "You feel like you're the problem — when you're actually just missing the right tool" } }
      ]
    }
  ]
}
{% endschema %}
