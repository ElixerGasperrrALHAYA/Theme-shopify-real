{{ 'twr-styles.css' | asset_url | stylesheet_tag }}

<div class="twr-wrapper">
  <section class="twr-pricing" id="buy">
    <div class="twr-pricing-inner">
      <div class="twr-section-label">{{ section.settings.section_label }}</div>
      <h2>{{ section.settings.headline }}</h2>
      <p class="twr-pricing-sub">{{ section.settings.subheadline }}</p>
      
      <div class="twr-price-box">
        <div class="twr-price-cross">{{ section.settings.price_cross }}</div>
        <div class="twr-price-main"><sup>{{ section.settings.currency }}</sup>{{ section.settings.price }}<sub>{{ section.settings.price_suffix }}</sub></div>
        <div class="twr-price-desc">{{ section.settings.price_desc }}</div>
        
        <ul class="twr-price-includes">
          {% for block in section.blocks %}
            <li>{{ block.settings.list_item }}</li>
          {% endfor %}
        </ul>
        
        <button 
          type="button" 
          class="twr-cta-main twr-large add-to-cart-drawer" 
          data-variant-id="{{ section.settings.product.selected_or_first_available_variant.id | default: section.settings.variant_id }}"
        >
          {{ section.settings.button_text }}
        </button>
      </div>
      
      {% if section.settings.show_guarantee %}
      <div class="twr-guarantee">
        <div class="twr-guarantee-icon">🛡️</div>
        <div class="twr-guarantee-text">
          <h4>{{ section.settings.guarantee_title }}</h4>
          <p>{{ section.settings.guarantee_text }}</p>
        </div>
      </div>
      {% endif %}
    </div>
  </section>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Slow scroll for all .smooth-scroll links
  document.querySelectorAll('.smooth-scroll').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const targetId = this.getAttribute('href');
      const targetElement = document.querySelector(targetId);
      if (targetElement) {
        targetElement.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });

  // Cart Drawer Trigger
  document.querySelectorAll('.add-to-cart-drawer').forEach(button => {
    button.addEventListener('click', async function() {
      const variantId = this.dataset.variantId;
      if (!variantId) {
        alert('Please select a product in the section settings.');
        return;
      }
      
      try {
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
        });
        
        if (response.ok) {
          if (window.ThemeCartDrawer) {
            window.ThemeCartDrawer.open();
          } else {
            window.location.href = '/cart';
          }
        }
      } catch (error) {
        console.error('Error adding to cart:', error);
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "TWR Pricing",
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Section Label",
      "default": "Get Instant Access Today"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Start Your First Reset Today"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Sub Headline",
      "default": "One small decision. Three daily windows. Everything changes."
    },
    {
      "type": "text",
      "id": "price_cross",
      "label": "Crossed Price",
      "default": "$67 regular price"
    },
    {
      "type": "text",
      "id": "currency",
      "label": "Currency Symbol",
      "default": "$"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "27"
    },
    {
      "type": "text",
      "id": "price_suffix",
      "label": "Price Suffix",
      "default": "/one-time"
    },
    {
      "type": "text",
      "id": "price_desc",
      "label": "Price Description",
      "default": "Full access. No subscriptions. No hidden fees."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Get Instant Access — $27 →"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Main Product"
    },
    {
      "type": "text",
      "id": "variant_id",
      "label": "Manual Variant ID (if not selecting product)",
      "info": "Use this if you prefer to hardcode the ID"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link (Fallback)"
    },
    {
      "type": "checkbox",
      "id": "show_guarantee",
      "label": "Show Guarantee",
      "default": true
    },
    {
      "type": "text",
      "id": "guarantee_title",
      "label": "Guarantee Title",
      "default": "30-Day Money Back Guarantee"
    },
    {
      "type": "textarea",
      "id": "guarantee_text",
      "label": "Guarantee Text",
      "default": "Try it for 30 days. If you don't feel a difference in how you handle cravings, email us and we'll refund every penny. No questions, no hassle."
    }
  ],
  "blocks": [
    {
      "type": "include_item",
      "name": "Included Item",
      "settings": [
        {
          "type": "text",
          "id": "list_item",
          "label": "Item Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TWR Pricing",
      "blocks": [
        { "type": "include_item", "settings": { "list_item": "Three Window Reset — Main Guide (PDF)" } },
        { "type": "include_item", "settings": { "list_item": "Quick Reference Card (print-ready)" } },
        { "type": "include_item", "settings": { "list_item": "Craving Emergency Script" } },
        { "type": "include_item", "settings": { "list_item": "Instant download — access in 2 minutes" } },
        { "type": "include_item", "settings": { "list_item": "Works on phone, tablet, or computer" } }
      ]
    }
  ]
}
{% endschema %}
