<div class="founder-story-wrapper" style="--bg-color: {{ section.settings.bg_color }}; --text-color: {{ section.settings.text_color }};">
  <div class="founder-story-container">
    {%- if section.settings.image != blank -%}
      <div class="founder-image-wrapper">
        {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'founder-img' }}
      </div>
    {%- endif -%}

    <div class="founder-story-content">
      {%- if section.settings.quote_icon != blank -%}
        <div class="story-quote-icon">{{ section.settings.quote_icon }}</div>
      {%- endif -%}

      {%- if section.settings.story_text != blank -%}
        <div class="story-text-body">
          {{ section.settings.story_text }}
        </div>
      {%- endif -%}

      {%- if section.settings.author_name != blank -%}
        <div class="story-author">
          <strong>{{ section.settings.author_name }}</strong>
          {%- if section.settings.author_title != blank -%}
            <br>
            <span class="story-author-title">{{ section.settings.author_title }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .founder-story-wrapper {
    background-color: var(--bg-color);
    color: var(--text-color);
    padding: 60px 20px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
  .founder-story-container {
    max-width: 680px;
    margin: 0 auto;
  }
  .founder-image-wrapper {
    margin-bottom: 40px;
    border-radius: 8px;
    overflow: hidden;
  }
  .founder-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
  .story-quote-icon {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 20px;
    opacity: 0.2;
    font-family: Georgia, serif;
  }
  .story-text-body {
    font-size: 1.125rem;
    line-height: 1.6;
    margin-bottom: 30px;
  }
  .story-text-body p {
    margin-bottom: 16px;
  }
  .story-text-body p:last-child {
    margin-bottom: 0;
  }
  .story-author {
    font-size: 1rem;
    line-height: 1.4;
  }
  .story-author-title {
    opacity: 0.7;
    font-size: 0.9rem;
  }
  @media (min-width: 768px) {
    .founder-story-wrapper {
      padding: 80px 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Founder Story",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F8F9FA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Story Image (UGC / Authentic style highly recommended)"
    },
    {
      "type": "text",
      "id": "quote_icon",
      "label": "Quote Icon",
      "default": "“"
    },
    {
      "type": "richtext",
      "id": "story_text",
      "label": "Story Body Text",
      "default": "<p>I had a moment I'll never forget...</p><p>I went shopping for an event... and nothing felt right on me. Not even the larger sizes. It wasn't just about my weight. It was the feeling I couldn't control what was happening with my body anymore...</p>"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author Name",
      "default": "Sarah P."
    },
    {
      "type": "text",
      "id": "author_title",
      "label": "Author Title / Subtitle",
      "default": "Early adopter of the Habit"
    }
  ],
  "presets": [
    {
      "name": "Founder Story",
      "category": "High Conversion"
    }
  ]
}
{% endschema %}
