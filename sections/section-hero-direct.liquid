<div class="hero-direct-wrapper" style="--bg-color: {{ section.settings.bg_color }}; --text-color: {{ section.settings.text_color }};">
  <div class="hero-direct-container">
    {%- if section.settings.microtext_top != blank -%}
      <div class="hero-microtext-top">
        {{ section.settings.microtext_top }}
      </div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero-heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <div class="hero-subtext">
        {{ section.settings.subtext }}
      </div>
    {%- endif -%}

    <div class="hero-cta-wrapper">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" 
           class="hero-btn" 
           style="--btn-bg: {{ section.settings.btn_color }}; --btn-text: {{ section.settings.btn_text_color }};">
           {%- if section.settings.button_icon != blank -%}
             <span class="btn-icon">{{ section.settings.button_icon }}</span>
           {%- endif -%}
           {{ section.settings.button_label }}
        </a>
      {%- endif -%}
      
      {%- if section.settings.microtext_bottom != blank -%}
        <div class="hero-microtext-bottom">
          {{ section.settings.microtext_bottom }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .hero-direct-wrapper {
    background-color: var(--bg-color);
    color: var(--text-color);
    padding: 60px 20px;
    text-align: center;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
  .hero-direct-container {
    max-width: 800px;
    margin: 0 auto;
  }
  .hero-microtext-top {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background-color: #E6F7F1;
    color: #0d5f47;
    display: inline-block;
    padding: 6px 12px;
    border-radius: 20px;
    margin-bottom: 24px;
  }
  .hero-heading {
    font-size: 2.5rem;
    line-height: 1.1;
    font-weight: 800;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }
  .hero-subtext {
    font-size: 1.125rem;
    line-height: 1.5;
    margin-bottom: 40px;
    color: inherit;
    opacity: 0.85;
  }
  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--btn-bg);
    color: var(--btn-text);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.25rem;
    padding: 18px 32px;
    border-radius: 8px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
    max-width: 400px;
    gap: 10px;
  }
  .hero-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
  }
  .hero-microtext-bottom {
    font-size: 0.9rem;
    margin-top: 16px;
    opacity: 0.7;
    font-style: italic;
  }
  @media (min-width: 768px) {
    .hero-heading {
      font-size: 3.5rem;
    }
    .hero-subtext {
      font-size: 1.25rem;
    }
    .hero-direct-wrapper {
      padding: 100px 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Direct Response",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F8F9FA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "text",
      "id": "microtext_top",
      "label": "Top Microtext",
      "default": "Made for women who feel stuck"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Main Heading (H1)",
      "default": "The Simple Daily Habit That Finally Worked For Me — even when cravings were hard"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext / Objections",
      "default": "<p>No gym pressure. No strict dieting.<br>Just a simple routine your body can follow.</p>"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "See the simple routine"
    },
    {
      "type": "text",
      "id": "button_icon",
      "label": "Button Icon (Emoji)",
      "default": "💛"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button Background",
      "default": "#2D68FF"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "richtext",
      "id": "microtext_bottom",
      "label": "Bottom Microtext",
      "default": "<p>Join 3,800+ women already following this routine</p>"
    }
  ],
  "presets": [
    {
      "name": "Hero Direct Response",
      "category": "High Conversion"
    }
  ]
}
{% endschema %}
